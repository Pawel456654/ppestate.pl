NEXT_PUBLIC_SITE_URL=https://twojadomena.pl
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Panel administracyjny (/panel-admin)
ADMIN_PASSWORD=ustaw-mocne-haslo
ADMIN_SESSION_SECRET=losowy-dlugi-ciag-znakow

# EstiCRM API (synchronizacja ofert)
ESTI_COMPANY_ID=
ESTI_API_TOKEN=
ESTI_API_BASE_URL=https://app.esticrm.pl/apiClient
# Statusy ofert traktowane jako aktywne (domyślnie 3 = publikowana, 99 = wewnętrzna)
ESTI_SYNC_STATUS_FILTER=3,99
# Rozmiar strony przy pobieraniu ofert (paginacja skip/take)
ESTI_SYNC_BATCH_SIZE=50

# Zabezpieczenie endpointu cron /api/cron/sync-esti
CRON_SECRET=losowy-dlugi-ciag-znakow
