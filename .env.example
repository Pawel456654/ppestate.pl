NEXT_PUBLIC_SITE_URL=https://twojadomena.pl
# Publiczny adres strony (np. https://ppestate.pl) — NIE URL Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Alternatywnie (nowy panel Supabase): NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Alternatywnie (nowy panel Supabase): SUPABASE_SECRET_KEY=sb_secret_...

# Panel administracyjny (/panel-admin)
ADMIN_PASSWORD=ustaw-mocne-haslo
ADMIN_SESSION_SECRET=losowy-dlugi-ciag-znakow

# EstiCRM API (synchronizacja ofert)
ESTI_COMPANY_ID=
ESTI_API_TOKEN=
ESTI_API_BASE_URL=https://app.esticrm.pl/apiClient
# Statusy Esti do synchronizacji: 3=aktywna, 4=rezerwacja, 7=sprzedana, 99=wewnętrzna
# Dodaj kod negocjacji po weryfikacji słownika offer/dictionary w EstiCRM
ESTI_SYNC_STATUS_FILTER=3,4,7,99
# Rozmiar strony przy pobieraniu ofert (paginacja skip/take)
ESTI_SYNC_BATCH_SIZE=50

# Zabezpieczenie endpointu cron /api/cron/sync-esti
CRON_SECRET=losowy-dlugi-ciag-znakow
